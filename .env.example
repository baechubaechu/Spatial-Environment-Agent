# FastAPI(exhibition-agent) — exhibition-agent 폴더에서 uvicorn 실행 시 로드 (env_load가 web/.env.local 도 읽음)

# 이벤트 버스 = 제어 웹 앱 주소 (태블릿 테스트 시 데스크톱 LAN IP:3001 로 바꿀 수 있음)
# EVENT_BRIDGE_BASE_URL=http://127.0.0.1:3001

# 제어 웹을 HTTPS 로 띄울 때 (루트의 start-dev.bat 참고)
# EVENT_BRIDGE_BASE_URL=https://127.0.0.1:3001
# 자체 서명 인증서 허용 — 운영 TLS 에서는 설정하지 말 것
# EVENT_BRIDGE_SSL_VERIFY=false

# 이벤트 소비 폴링(기본 0.15s). 버튼→조명 반응을 더 빠르게 하려면 유지·미세 조정
# EVENT_CONSUME_POLL_SEC=0.15
# 하트비트 최소 간격(기본 2s) — 폴링만 빠르게 할 때 POST 과다 방지
# EVENT_HEARTBEAT_MIN_INTERVAL_SEC=2

# 조명 브리지: ESP32 펌웨어 — 개인망은 esp32_http_light.ino / 홍익 WPA2-Enterprise 는 esp32_http_light_ent.ino
# 예: EXHIBITION_LIGHT_HTTP_URL=http://192.168.144.50
# EXHIBITION_LIGHT_HTTP_TOKEN=

# 시그니지(선택)
# EXHIBITION_DISPLAY_HTTP_URL=
