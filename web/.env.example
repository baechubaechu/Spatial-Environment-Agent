NEXT_PUBLIC_APP_NAME=전시 제어

# 센서·프리뷰 카메라: 미설정 또는 host = 노트북 웹캠(/host-exhibit-capture), tablet = 태블릿 도면 페이지
# NEXT_PUBLIC_EXHIBIT_CAPTURE_SOURCE=tablet
# 호스트 전용: 웹캠 deviceId (미설정 시 시스템 기본 카메라). 마이크는 보통 웹캠 내장만 쓰고 OS 기본 입력으로 맞춤 → 아래 생략 가능
# NEXT_PUBLIC_EXHIBIT_HOST_VIDEO_DEVICE_ID=
# NEXT_PUBLIC_EXHIBIT_HOST_AUDIO_DEVICE_ID=

# 제어 패널에서 Vision 호출 (파이널 직전까지 false 권장)
NEXT_PUBLIC_ENABLE_VISION_RUNTIME=false
# 비전 없이도 벽면 TV(/signage)에 카메라 JPEG만 올리려면 true (Vision과 독립). 호스트 웹캠 모드에서 이 페이지에서 업로드
# NEXT_PUBLIC_ENABLE_EXHIBIT_CAMERA_PREVIEW=true
# 로컬만: NEXT_PUBLIC_VISION_API_URL=http://127.0.0.1:8000/analyze
# 태블릿 같은 Wi-Fi: 브라우저가 접속하는 기기 기준으로 반드시 데스크톱 IP 사용 (localhost 금지)
# NEXT_PUBLIC_VISION_API_URL=http://192.168.137.1:8000/analyze

# 이벤트 헬스 스크립트: npm run check:event-bus
# EVENT_BRIDGE_BASE_URL=http://127.0.0.1:3001

# 벽면 TV /signage 가 서버에서 에이전트 상태를 가져올 때 (기본 http://127.0.0.1:8000)
# EXHIBITION_AGENT_BASE_URL=http://127.0.0.1:8000

# 태블릿 → 호스트 TV 카메라 프리뷰 업로드·/signage 폴링 간격(ms). 최소 125 (미설정 시 125)
# NEXT_PUBLIC_EXHIBIT_PREVIEW_INTERVAL_MS=250
